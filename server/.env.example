# RealCommerce API environment configuration

NODE_ENV=development
PORT=4000
API_PREFIX=/api
APP_NAME=realcommerce-api
TRUST_PROXY=false
LOG_LEVEL=debug
LOG_FORMAT=pretty

# CORS
CLIENT_ORIGIN=http://localhost:3000
# CLIENT_ORIGIN_REGEX=

# PostgreSQL
# Prefer DATABASE_URL for hosted environments:
# DATABASE_URL=postgresql://user:pass@host:5432/realcommerce?sslmode=require
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=
PGDATABASE=realcommerce
PG_MAINTENANCE_DB=postgres
PGSSL=false
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=10000
DB_STATEMENT_TIMEOUT_MS=15000
DB_QUERY_TIMEOUT_MS=15000

# Sessions
SESSION_SECRET=CHANGE-ME-TO-A-64-CHAR-RANDOM-STRING
SESSION_COOKIE_NAME=rc_session
SESSION_TTL_DAYS=14
SESSION_COOKIE_DOMAIN=
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAME_SITE=Lax

# Auth rate limiting (per IP + email)
AUTH_RATE_LIMIT_WINDOW_MS=600000
AUTH_LOGIN_RATE_LIMIT_MAX_ATTEMPTS=8
AUTH_REGISTER_RATE_LIMIT_MAX_ATTEMPTS=4

# Global API rate limiting
GLOBAL_RATE_LIMIT_WINDOW_MS=900000
GLOBAL_RATE_LIMIT_MAX_REQUESTS=300

# Commerce
TAX_RATE=0.075
FREE_SHIPPING_THRESHOLD=1200

# External exchange-rate sync
EXCHANGE_RATE_PROVIDER=frankfurter
EXCHANGE_RATE_PROVIDER_BASE_URL=https://api.frankfurter.app
EXCHANGE_RATE_SYNC_ENABLED=true
EXCHANGE_RATE_SYNC_INTERVAL_MS=3600000
EXCHANGE_RATE_SYNC_TIMEOUT_MS=10000

# Media storage (Google Cloud Storage)
MEDIA_STORAGE_PROVIDER=gcs
GCS_PROJECT_ID=
GCS_BUCKET_NAME=
GCS_KEY_FILENAME=
# GCS_CREDENTIALS_JSON=
# GCS_CREDENTIALS_BASE64=
GCS_UPLOAD_URL_EXPIRES_SECONDS=900
GCS_PUBLIC_BASE_URL=
