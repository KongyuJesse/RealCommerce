{
  "name": "realcommerce-workspace",
  "private": true,
  "scripts": {
    "install:all": "npm install --prefix client && npm install --prefix server",
    "dev": "concurrently \"npm --prefix server run dev\" \"npm --prefix client start\"",
    "client": "npm --prefix client start",
    "server": "npm --prefix server run dev",
    "server:start": "npm --prefix server run start",
    "build": "npm --prefix client run build",
    "test": "npm --prefix client run test:ci",
    "db:init": "npm --prefix server run db:init"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
